# 1. CẤU HÌNH TRÍ TUỆ NHÂN TẠO GEMINI (YÊU CẦU ĐỂ TƯ VẤN PHONG THỦY)
# Lấy API key tại: https://aistudio.google.com/
GEMINI_API_KEY="MÃ_KEY_GEMINI_CỦA_BẠN"

# 2. CẤU HÌNH CƠ SỞ DỮ LIỆU POSTGRESQL (DRIZZLE ORM)
# Chuyển đổi các cấu hình kết nối tương ứng với Cloud SQL hoặc PostgreSQL cục bộ của bạn
SQL_HOST="localhost"
SQL_USER="postgres"
SQL_PASSWORD="your_password"
SQL_DB_NAME="vietsim_db"

# 3. CẤU HÌNH ĐƯỜNG DẪN ỨNG DỤNG
# Đường dẫn chạy máy chủ cục bộ hoặc domain triển khai thực tế
APP_URL="http://localhost:3000"

# Cấu hình địa chỉ máy chủ Express API gốc (Ví dụ: http://localhost:3000 hoặc http://127.0.0.1:3000)
# Next.js sẽ chuyển tiếp (rewrite/proxy) các API chưa cài đặt trực tiếp sang máy chủ này
BACKEND_URL="http://localhost:3000"

# 4. CHẾ ĐỘ MÔ PHỎNG (SIMULATION MODE)
# Đặt "true" để hiển thị thanh gạt chuyển đổi "Mô phỏng" và giả lập phân quyền
# Đặt "false" để khóa cứng ở chế độ "Thực tế", bắt buộc đăng nhập tài khoản đại lý đối tác thực sự
ALLOW_ROLE_SIMULATION="true"
